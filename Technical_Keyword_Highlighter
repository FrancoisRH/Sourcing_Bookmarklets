var flags="gi";
var style="background-color:#FFE066;color:#000;border-radius:3px;padding:0 2px;font-weight:bold;";

function escapeRegex(s){return s.replace(/[-\/\\^$*+?.()|[\]{}]/g,'\\$&');}

function walkAndHighlight(node){
  if(node.nodeType===3){
    var text=node.nodeValue;
    var matched=false;
    var temp=document.createElement('span');
    var result=text;
    keywords.forEach(function(kw){
      var re=new RegExp('\\b'+escapeRegex(kw)+'\\b',flags);
      if(re.test(result)){matched=true;}
      result=result.replace(re,'<mark style="'+style+'">$&</mark>');
    });
    if(matched){
      temp.innerHTML=result;
      node.parentNode.replaceChild(temp,node);
    }
  } else if(node.nodeType===1&&!/^(SCRIPT|STYLE|TEXTAREA|INPUT|SELECT|MARK)$/.test(node.tagName)){
    Array.from(node.childNodes).forEach(walkAndHighlight);
  }
}

walkAndHighlight(document.body);
alert('✅ Technical keywords highlighted!');
})();

